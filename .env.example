# Local SQLite database. Relative paths are resolved from the launch directory.
DATABASE_PATH=data/world-cup.sqlite3

# Optional. The current implementation works without a token by using OpenFootball.
FOOTBALL_DATA_API_TOKEN=

# Refresh and simulation settings.
REFRESH_INTERVAL_MINUTES=15
LIVE_REFRESH_INTERVAL_MINUTES=2
SIMULATION_ITERATIONS=50000
SIMULATION_SEED=20260613

